pkgname=typetomusic
pkgver=1.0.0
pkgrel=1
pkgdesc="Turn keyboard typing into MIDI music in real time"
arch=('any')
url="https://github.com/typetomusic/typetomusic"
license=('MIT')
depends=('python>=3.9' 'python-pyqt5')
optdepends=(
  'python-pynput: X11 global keyboard capture backend'
  'python-evdev: Wayland/raw input backend'
  'python-pyfluidsynth: FluidSynth Python bridge'
  'fluidsynth: MIDI synthesis runtime'
  'soundfont-fluid: default GM SoundFont'
  'pipewire: preferred audio stack'
  'pulseaudio: audio stack fallback'
)
source=("${pkgname}-${pkgver}.tar.gz")
sha256sums=('SKIP')

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  install -d "${pkgdir}/usr/bin"
  install -d "${pkgdir}/usr/share/typetomusic"
  install -d "${pkgdir}/usr/share/applications"

  install -m755 packaging/deb/usr/bin/typetomusic "${pkgdir}/usr/bin/typetomusic"
  install -m644 packaging/deb/usr/share/applications/typetomusic.desktop "${pkgdir}/usr/share/applications/typetomusic.desktop"

  cp -a main.py typetomusic requirements.txt "${pkgdir}/usr/share/typetomusic/"

  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
