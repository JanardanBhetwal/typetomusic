#!/bin/bash
# TypeToMusic launcher
# Installed to /usr/bin/typetomusic by the .deb package

INSTALL_DIR="/usr/share/typetomusic"

# Use the virtual environment if it exists, otherwise system Python
if [ -f "$INSTALL_DIR/venv/bin/python3" ]; then
    exec "$INSTALL_DIR/venv/bin/python3" "$INSTALL_DIR/main.py" "$@"
else
    exec python3 "$INSTALL_DIR/main.py" "$@"
fi
